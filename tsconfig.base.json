{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["ESNext", "DOM"],
    "jsx": "react",
    "moduleResolution": "Node",
    "types": ["@types/node"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"]
}
