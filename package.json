{
  "name": "@potato4d/dodai",
  "version": "0.6.0",
  "description": "static website generator",
  "main": "./dist/index.js",
  "module": "./dist/esm/hotreload.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./hotreload": {
      "import": {
        "types": "./dist/esm/hotreload.d.ts",
        "default": "./dist/esm/hotreload.js"
      },
      "require": {
        "types": "./dist/hotreload.d.ts",
        "default": "./dist/hotreload.js"
      }
    },
    "./dist/hotreload": {
      "import": "./dist/esm/hotreload.js",
      "require": "./dist/hotreload.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "npm run test",
    "build": "tsc && tsc -p tsconfig.esm.json && node ./scripts/postbuild.js"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/potato4d/dodai.git"
  },
  "keywords": [
    "static",
    "ssg",
    "build",
    "static-site-generator"
  ],
  "bin": {
    "dodai": "./dist/index.js"
  },
  "author": "potato4d (Takuma HANATANI)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/potato4d/dodai/issues"
  },
  "homepage": "https://github.com/potato4d/dodai#readme",
  "dependencies": {
    "@types/consola": "^2.2.5",
    "chokidar": "^3.5.3",
    "commander": "^9.4.1",
    "consola": "^2.15.3",
    "express": "^4.18.2",
    "fs-extra": "^11.1.0",
    "get-port-please": "^3.0.1",
    "glob": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.15",
    "@types/fs-extra": "^9.0.13",
    "@types/glob": "^8.0.0",
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.26",
    "@types/react-dom": "^18.0.10",
    "rome": "^0.10.1",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.4"
  }
}
